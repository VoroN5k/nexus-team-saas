# Database credentials (використовуються docker-compose і сервером)
# Генерувати пароль: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# pgAdmin (тільки для локального --profile tools)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# DATABASE_URL для NestJS (складається з вищезазначених)
DATABASE_URL=postgresql://nexus:REPLACE_WITH_RANDOM_PASSWORD@localhost:5432/nexus

# JWT
# Генерувати: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# OPAQUE
# КРИТИЧНО: якщо не встановити, при кожному рестарті сервера всі OPAQUE записи
# стануть недійсними і жоден користувач не зможе увійти!
#
# Як згенерувати:
#   1. Запусти сервер один раз БЕЗ цієї змінної
#   2. Скопіюй значення з логів: "OPAQUE_SERVER_SETUP=<value>"
#   3. Встав сюди і більше ніколи не змінюй
OPAQUE_SERVER_SETUP=

# CORS
# Для локальної розробки:
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Для production (після деплою на Fly.io):
# ALLOWED_ORIGINS=https://nexus-team-app.fly.dev

# Email (опціонально)
# Якщо не встановлено — email відправляється в JSON лог (dev режим)
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USER=apikey
# MAIL_PASS=SG.your-sendgrid-api-key

# Fly.io specific
# PORT=8080  # встановлюється Fly.io автоматично
# NODE_ENV=production
