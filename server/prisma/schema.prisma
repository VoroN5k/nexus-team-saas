generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  EXPIRED
  DENIED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  firstName        String?
  lastName         String?
  password         String
  isEmailVerified  Boolean  @default(false)
  emailVerifyToken String?
  /// RSA-OAEP SPKI public key (base64) — published by client for vault share encryption
  publicKey        String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions         Session[]
  workspaces       WorkspaceMember[]
  tasks            Task[]            @relation("AssignedTasks")
  vaultsCreated    Vault[]           @relation("VaultCreator")
  vaultShares      VaultShare[]      @relation("VaultShareHolder")
  accessRequests   AccessRequest[]   @relation("AccessRequester")
  shareSubmissions ShareSubmission[] @relation("ShareSubmitter")
  invitesCreated   WorkspaceInvite[] @relation("InviteCreator")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  tasks   Task[]
  vaults  Vault[]
  invites WorkspaceInvite[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  workspaceId String
  assignedId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assigned  User?     @relation("AssignedTasks", fields: [assignedId], references: [id], onDelete: SetNull)
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  deviceName   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Shareable invite link (token hashed, single or multi-use, with TTL)
model WorkspaceInvite {
  id          String   @id @default(uuid())
  workspaceId String
  createdById String
  tokenHash   String   @unique
  maxUses     Int?
  useCount    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
}

model Vault {
  id          String   @id @default(uuid())
  workspaceId String
  createdById String
  name        String
  description String?
  threshold   Int
  totalShares Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("VaultCreator", fields: [createdById], references: [id])
  shares         VaultShare[]
  accessRequests AccessRequest[]
}

model VaultShare {
  id              String   @id @default(uuid())
  vaultId         String
  holderId        String
  shareIndex      Int
  encryptedShare  String   @db.Text
  holderPublicKey String   @db.Text
  createdAt       DateTime @default(now())

  vault  Vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  holder User  @relation("VaultShareHolder", fields: [holderId], references: [id])

  @@unique([vaultId, holderId])
  @@unique([vaultId, shareIndex])
  @@index([holderId])
}

model AccessRequest {
  id          String              @id @default(uuid())
  vaultId     String
  requesterId String
  status      AccessRequestStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())

  vault       Vault             @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  requester   User              @relation("AccessRequester", fields: [requesterId], references: [id])
  submissions ShareSubmission[]
}

model ShareSubmission {
  id              String   @id @default(uuid())
  accessRequestId String
  holderId        String
  share           String   @db.Text
  submittedAt     DateTime @default(now())

  accessRequest AccessRequest @relation(fields: [accessRequestId], references: [id], onDelete: Cascade)
  holder        User          @relation("ShareSubmitter", fields: [holderId], references: [id])

  @@unique([accessRequestId, holderId])
}
