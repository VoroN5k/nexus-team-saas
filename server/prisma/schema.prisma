generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String?
  lastName String?
  password  String  
  isEmailVerified Boolean @default(false)
  emailVerifyToken String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  workspaces WorkspaceMember[]
  tasks Task[] @relation("AssignedTasks")
}

model Workspace {
  id String @id @default(uuid())
  name String
  slug String @unique // for urls
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  tasks Task[]
}

// table for multi-tenancy and user roles in workspaces
model WorkspaceMember {
  id String @id @default(uuid())
  userId String
  workspaceId String
  role Role @default(MEMBER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Task {
  id String @id @default(uuid())
  title String
  description String?
  status TaskStatus @default(TODO)

  // MULTI TENANT
  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  assignedId String?
  assigned User? @relation("AssignedTasks", fields: [assignedId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model Session {
  id        String   @id @default(uuid())
  userId    String
  refreshToken     String   @unique
  userAgent String?
  ipAddress String?
  deviceName String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
